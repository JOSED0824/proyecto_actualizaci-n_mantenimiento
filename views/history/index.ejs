<style>
    .pet-card { transition: transform 0.3s ease; }
    .pet-card:hover { transform: translateY(-4px); }
    .species-badge {
        background-color: #1e3a5f;
        color: #93c5fd;
        border: 1px solid #2563eb;
        font-size: 0.75rem;
        padding: 2px 8px;
        border-radius: 20px;
    }
    .visit-count {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary-color);
        line-height: 1;
    }
    .empty-state { color: var(--text-muted); }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-0">📋 Historial Clínico</h2>
        <p class="text-muted mb-0 mt-1">Expedientes médicos de pacientes registrados</p>
    </div>
    <span class="badge" style="font-size:0.85rem; padding:6px 14px;">
        <%= pets.length %> paciente<%= pets.length !== 1 ? 's' : '' %>
    </span>
</div>

<% if (pets.length === 0) { %>
    <div class="card text-center py-5 empty-state">
        <div class="card-body">
            <div style="font-size:3rem;">🐾</div>
            <h5 class="mt-3">Sin registros aún</h5>
            <p class="text-muted">No hay mascotas con citas registradas en el sistema.</p>
            <a href="/create" class="btn btn-primary mt-2">Agendar primera cita</a>
        </div>
    </div>
<% } else { %>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <% pets.forEach(pet => { %>
            <div class="col">
                <div class="card h-100 pet-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h5 class="card-title mb-0"><%= pet.name %></h5>
                            <span class="species-badge"><%= pet.species %></span>
                        </div>
                        <p class="card-text text-muted mb-3">
                            <small>👤 <%= pet.owner_name %></small>
                            <% if (pet.breed) { %>
                                <br><small>🔖 <%= pet.breed %></small>
                            <% } %>
                        </p>
                        <div class="d-flex align-items-end justify-content-between">
                            <div>
                                <div class="visit-count"><%= pet.visit_count %></div>
                                <small class="text-muted">visita<%= pet.visit_count !== 1 ? 's' : '' %></small>
                            </div>
                            <a href="/history/<%= pet.id %>" class="btn btn-primary btn-sm">
                                Ver Historial →
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>
