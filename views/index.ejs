<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h2">Panel de Citas</h1>
    <a href="/create" class="btn btn-primary">Nueva Cita</a>
</div>

<div class="row">
    <% if (appointments.length === 0) { %>
        <div class="col-12 text-center py-5">
            <p class="text-muted">No hay citas programadas.</p>
        </div>
    <% } else { %>
        <% appointments.forEach(app => { %>
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">

                        <%# ── Encabezado ──────────────────────────────────── %>
                        <div class="d-flex justify-content-between align-items-start">
                            <h5 class="card-title text-primary">
                                <%= app.pet_name %>
                                <small class="text-muted fw-normal fs-6">(<%= app.species %>)</small>
                            </h5>
                            <span class="badge" style="background-color: #e0e0ff; color: #6c5ce7;">
                                <%= app.status %>
                            </span>
                        </div>

                        <%# ── Datos básicos ───────────────────────────────── %>
                        <p class="card-text mb-1">
                            <strong>Dueño:</strong> <%= app.owner_name %>
                        </p>
                        <p class="card-text mb-1">
                            <strong>Servicio:</strong> <%= app.service %>
                        </p>
                        <p class="card-text mb-3">
                            <strong>Fecha:</strong> <%= app.appointment_date %>
                        </p>

                        <%# ── Constantes vitales (solo si existen) ────────── %>
                        <% if (app.weight || app.temperature || app.diagnosis) { %>
                            <hr>
                            <p class="text-muted small mb-2">🩺 Constantes Vitales</p>
                            <% if (app.weight) { %>
                                <p class="card-text mb-1">
                                    <strong>Peso:</strong> <%= app.weight %> kg
                                </p>
                            <% } %>
                            <% if (app.temperature) { %>
                                <p class="card-text mb-1">
                                    <strong>Temperatura:</strong> <%= app.temperature %> °C
                                </p>
                            <% } %>
                            <% if (app.diagnosis) { %>
                                <p class="card-text mb-3">
                                    <strong>Diagnóstico:</strong> <%= app.diagnosis %>
                                </p>
                            <% } %>
                        <% } %>

                        <%# ── Eliminar ─────────────────────────────────────── %>
                        <form action="/delete/<%= app.id %>" method="POST"
                            onsubmit="return confirm('¿Eliminar esta cita?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                        </form>

                    </div>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>